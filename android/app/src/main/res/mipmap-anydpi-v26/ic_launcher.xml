<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (Android 8.0+). The launcher masks the foreground to
  whatever shape the device theme uses — circle, squircle, rounded square — so
  the emblem is drawn at 66% of the 108dp canvas to stay inside the 72dp safe
  zone. Pre-Oreo devices fall back to the flat mipmap-*/ic_launcher.png.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
